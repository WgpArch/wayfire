{
    "layer": "top",
    "position": "top",
    "height": 35,
    "spacing": 4,
    "margin-top": 0,
    "margin-bottom":0,
    "modules-left":[  "custom/launcher", "custom/player"],
    "modules-center":["clock", "custom/weather"],
    "modules-right":["tray", "network", "battery", "disk", "cpu", "temperature", "memory", "pulseaudio", "custom/notification", "custom/power"],


    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 20,
        "icon-theme": "Star",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "on-click-right": "minimize"
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "’ä£ {name} {icon}",
        "format-icons": {
            "locked": "’ĆŻ",
            "unlocked": "’é£"
        }
    },
   "sway/language": {
        "format": "’ä£ {}",    
        "format": "{icon}",
        "format-icons": {
        "activated": "ŅÉŚ",
        "deactivated": "ŅŻĄ"
        }
    },
 
    "custom/launcher": {
        "format": "{} ’īā",
        "interval": 3600,
        "on-click": "rofi -show drun -theme ~/.config/rofi/sleek-dark.rasi",
        "tooltip": true,
        "tooltip-format": "btw ­¤śÄ"
    },

    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },

    "clock": {
        "interval": 1,
        "tooltip-format": "<big>{:%b %d}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%b %d %H:%M:%S %p}",
        "format-alt": "{:%Y-%m-%d}",
        "calendar": {
        "mode": "month",
        "mode-mon-col": 3,
        "week-pos": "right",
        "on-scroll": 1,
        "format": {
        "months":     "<span><b>{}</b></span>",
        "days":       "<span><b>{}</b></span>",
        "weeks":      "<span><b>W{}</b></span>",
        "weekdays":   "<span><b>{}</b></span>",
        "today":      "<span><b><u>{}</u></b></span>"
            }
     },
        "actions":  {
        "on-click-right": "mode",
        "on-scroll-up": "tz_up",
        "on-scroll-down": "tz_down",
        "on-scroll-up": "shift_up",
        "on-scroll-down": "shift_down"
        }
    },


    "network": {
       "interface": "wlp2s0",
       "format": "ŌÜĀ  Disabled",
       "format-wifi": "’ć½  {essid}",
       "format-ethernet": "’āü  Wired",
       "format-disconnected": "ŌÜĀ  Disconnected",
       "on-click": "nm-connection-editor"
   },

    "custom/weather": {
        "format": "{}",
        "tooltip": true,
        "interval": 300,
        "exec": "~/.config/waybar/scripts/weather.py",
        "return-type": "json"
   },


    "pulseaudio": {
        "reverse-scrolling": 1,
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}’Ŗö {format_source}",
        "format-bluetooth-muted": "’Ć”{icon}’Ŗö {format_source}",
        "format-muted": "’Ć” {format_source}",
        "format-source": "{volume}% ’ä░",
        "format-source-muted": "’ä▒",
        "format-icons": {
        "headphone": "’Ćź",
        "hands-free": "’Ćź",
        "headset": "’¤Ź",
        "phone": "’éĢ",
        "portable": "’éĢ",
        "car": "’å╣",
        "default": ["’Ć¦ ", " ’Ć©  "]
        },
        "on-click": "pavucontrol",
        "min-length": 13
    },

    "custom/notification": {
        "tooltip": false,
        "format": "{icon} ",
        "format-icons": {
        "notification": "’éó<span foreground='red'><sup><small>’æä</small></sup></span>",
        "none": "’éó",
        "dnd-notification": "’ćĘ<span foreground='red'><sup><small>’æä</small></sup></span>",
        "dnd-none": "’ćĘ",
        "inhibited-notification": "’éó<span foreground='red'><sup><small>’æä</small></sup></span>",
        "inhibited-none": "’éó",
        "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup><small>’æä</small></sup></span>",
        "dnd-inhibited-none": "’ćĘ"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
      },

    "cpu": {
        "format": "’ŗø  {usage}%",
        "tooltip": true,
        "on-click": "xfce4-terminal btop &"
    },
    "memory": {
        "format": "’āē  {}%",
		"tooltip": true,
		"on-click": "xfce4-terminal btop &"
    },
    "temperature": {
        "interval": 10,
        "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon5/temp1_input",
        "critical-threshold": 100,
        "format-critical": "’ŗć {temperatureC}",
        "format": "’ŗē {temperatureC}┬░C"
    },

    "battery": {
        "states": {
	"good": 95,
        "warning": 30,
        "critical": 20
        },
        "on-click-middle": "xfce-terminal acpi -i",
        "format": "{icon}  {capacity}%",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "’Ś¦  {capacity}%",
        "format-plugged": "’ć”  {capacity}%",
        "format-alt": "{time}  {icon}",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]        
    },
    
    "disk": {
        "format": "¾░ŗŖ {percentage_used}%",
        "tooltip-format": "{used} | {total}"
  },


    "custom/power": {
        "tooltip": false,
        "on-click": "~/.config/waybar1/rofi_powermenu",
        "on-click-right": "killall rofi",
        "format": "ŌÅ╗ "

    },
    "tray": {
        "icon-size": 16,
        "spacing": 0
},

   "custom/player": {
       "format": "­¤ÄĄ {}",
       "exec": "~/.config/waybar/scripts/player.sh",
       "interval": 3,
       "max-length": 25,
       "tooltip": true,
       "return-type": "text"
   
       }
}
